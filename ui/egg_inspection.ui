  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">#centralwidget { background-color: #f4f5f7; }
QLabel { color: #1a1d27; font-family: &quot;Segoe UI&quot;; }
#sidebar { background-color: #ffffff; border-right: 1px solid #e0e4e8; }
#sidebarTitle { color: #1a1d27; font: 16pt &quot;Segoe UI Semibold&quot;; font-weight: 600; padding-left: 5px; }
QPushButton { background-color: #e9ecef; color: #1a1d27; border: none; border-radius: 8px; padding: 12px 16px; text-align: left; font: 10pt &quot;Segoe UI&quot;; }
QPushButton:hover { background-color: #dee2e6; border-left: 3px solid #2f7df5; }
QPushButton:pressed { background-color: #cdd3d9; }
#detectButton { background-color: #2f7df5; color: #ffffff; font-weight: 600; text-align: center; border-radius: 8px; }
#detectButton:hover { background-color: #1a66d4; border-left: none; }
#detectButton:pressed { background-color: #14529f; }
#headerLabel { color: #1a1d27; font: 18pt &quot;Segoe UI Semibold&quot;; font-weight: 600; }
#inputTitle, #outputTitle { color: #6c757d; font: 9pt &quot;Segoe UI Semibold&quot;; font-weight: 600; letter-spacing: 1px; }
#originalImage, #resultImage { background-color: #ffffff; border: 1px solid #e0e4e8; border-radius: 12px; color: #6c757d; font: 10pt &quot;Segoe UI&quot;; }
QProgressBar { background-color: #e9ecef; border: none; border-radius: 4px; text-align: center; color: #ffffff; font-size: 8pt; }
QProgressBar::chunk { background-color: #2f7df5; border-radius: 4px; }
QFrame#card1, QFrame#card2, QFrame#card3, QFrame#card4 { background-color: #ffffff; border: 1px solid #e0e4e8; border-radius: 12px; }
QLabel#cardTitle { color: #6c757d; font: 8pt &quot;Segoe UI Semibold&quot;; font-weight: 600; letter-spacing: 1px; }
QLabel#card1Value { color: #1a1d27; font: 24pt &quot;Segoe UI Semibold&quot;; font-weight: 600; }
QLabel#card2Value { color: #28a745; font: 24pt &quot;Segoe UI Semibold&quot;; font-weight: 600; }
QLabel#card3Value { color: #dc3545; font: 24pt &quot;Segoe UI Semibold&quot;; font-weight: 600; }
QLabel#card4Value { color: #2f7df5; font: 24pt &quot;Segoe UI Semibold&quot;; font-weight: 600; }
QStatusBar { background-color: #ffffff; color: #6c757d; border-top: 1px solid #e0e4e8; font-size: 9pt; }
QStatusBar::item { border: none; }</string>
